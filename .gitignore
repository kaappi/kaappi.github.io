/site/
__pycache__/
# Fetched at build time from the matching kaappi release (scripts/fetch-wasm.sh);
# not committed, so release binaries don't bloat history. Run the script once
# before `mkdocs serve` on a fresh clone.
/docs/wasm/kaappi.wasm
# Same pattern for the embedded book PDF (scripts/fetch-book.sh), pinned by
# book_version in mkdocs.yml.
/docs/assets/kaappi-book.pdf
